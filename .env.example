# Frontend env (Vite). Copy to .env.local for development. In production, set
# these in the host (Vercel/Render) so they're embedded at build time.

# PostHog product analytics. Without these set, the analytics module no-ops.
# Get the key from PostHog → Project Settings → Project API Key.
VITE_POSTHOG_KEY=
# Optional: defaults to https://us.i.posthog.com (use https://eu.i.posthog.com
# for EU residency).
VITE_POSTHOG_HOST=

# Sentry error monitoring. Without the DSN the instrument module no-ops.
# Create a React project in Sentry → Settings → Client Keys (DSN).
VITE_SENTRY_DSN=
# Release tag attached to every event (shown in Sentry → Releases). The CI
# bundle inlines this at build time; bump on each deploy.
VITE_APP_VERSION=

# Source-map upload (build-time only, NOT shipped to the browser). Create a
# Sentry internal integration with project:releases scope and paste the
# token here. The Vite plugin no-ops without all three vars.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
