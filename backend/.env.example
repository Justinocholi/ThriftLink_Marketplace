SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

TERMII_API_KEY=
TERMII_SECRET_KEY=
TERMII_SENDER_ID=ThriftLink

JWT_SECRET=
JWT_EXPIRES_IN=7d

# Manual bank transfer destination (shown to customers at checkout)
PAYMENT_BANK_NAME=
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_ACCOUNT_NAME=

# Email (SMTP). If unset, emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Thrift-Link <no-reply@thriftlink.local>

FRONTEND_URL=http://localhost:5173

# 'sqlite' (default) or 'supabase'
DATA_BACKEND=sqlite

# Mailboxlayer — pre-flight email verification at signup. Get at mailboxlayer.com.
# When unset, the verifier no-ops; signups proceed unchecked.
MAILBOXLAYER_KEY=

# When 'true', registration uses Supabase Auth's signUp flow so Supabase
# sends a confirmation email from THEIR verified domain (no Resend domain
# required). Requires the dashboard toggle
# Authentication → Providers → Email → "Confirm email" = ON.
SUPABASE_REQUIRE_EMAIL_CONFIRMATION=
